# ─────────────────────────────────────────────────────────
# MilestoneGG — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.
# ─────────────────────────────────────────────────────────

# From Supabase → Project Settings → API
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-public-key-here

# Your personal admin secret — anything you want, keep it private
# This is what you type on the "Admin Access" screen
REACT_APP_ADMIN_SECRET=your-admin-secret-here
